{
  "name": "investmentportfolio-widget",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "samples/web/widgets/investmentportfolio-widget/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "qal",
      "options": {
        "compiler": "babel",
        "outputPath": "dist/apps/investmentportfolio-widget",
        "index": "samples/web/widgets/investmentportfolio-widget/src/index.html",
        "baseHref": "/",
        "main": "samples/web/widgets/investmentportfolio-widget/src/main.ts",
        "tsConfig": "samples/web/widgets/investmentportfolio-widget/tsconfig.app.json",
        "assets": [
          "samples/web/widgets/investmentportfolio-widget/src/favicon.ico",
          "samples/web/widgets/investmentportfolio-widget/src/assets",
          "samples/web/widgets/investmentportfolio-widget/src/locales"
        ],
        "styles": [],
        "scripts": [],
        "webpackConfig": "samples/web/widgets/investmentportfolio-widget/webpack.config.ts"
      },
      "configurations": {
        "development": {
          "extractLicenses": false,
          "optimization": false,
          "sourceMap": true,
          "vendorChunk": true
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.ts",
              "with": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false
        },
        "stage": {
          "fileReplacements": [
            {
              "replace": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.ts",
              "with": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false
        },
        "demo": {
          "fileReplacements": [
            {
              "replace": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.ts",
              "with": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": false,
          "vendorChunk": false
        },
        "preprod": {
          "fileReplacements": [
            {
              "replace": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.ts",
              "with": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.qal.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": true,
          "namedChunks": true,
          "extractLicenses": false,
          "vendorChunk": true
        },
        "qal": {
          "fileReplacements": [
            {
              "replace": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.ts",
              "with": "samples/web/widgets/investmentportfolio-widget/src/environments/environment.qal.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": true,
          "namedChunks": true,
          "extractLicenses": false,
          "vendorChunk": true
        }
      }
    },
    "serve": {
      "executor": "@nx/react:module-federation-dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "investmentportfolio-widget:build",
        "hmr": true,
        "port": 4302
      },
      "configurations": {
        "development": {
          "buildTarget": "investmentportfolio-widget:build:development"
        },
        "production": {
          "buildTarget": "investmentportfolio-widget:build:production",
          "hmr": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "defaultConfiguration": "production",
      "options": {
        "buildTarget": "investmentportfolio-widget:build",
        "watch": false,
        "port": 4302
      },
      "configurations": {
        "development": {
          "buildTarget": "investmentportfolio-widget:build:development"
        },
        "production": {
          "buildTarget": "investmentportfolio-widget:build:production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "{projectRoot}/jest.config.ts"
      }
    }
  }
}
