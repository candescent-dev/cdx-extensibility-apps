{
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "name": "investment-portfolio",
  "projectType": "library",
  "root": "samples/mobile/widgets/investment-portfolio",
  "sourceRoot": "samples/mobile/widgets/investment-portfolio/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/investment-portfolio"],
      "options": {
        "command": "npm run build && node ../../../../tools/scripts/stage-nx-package.js --projectRoot . --outDir ../../../../dist/packages/investment-portfolio --copy dist package.json README.md",
        "cwd": "samples/mobile/widgets/investment-portfolio"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev",
        "cwd": "samples/mobile/widgets/investment-portfolio"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run typecheck",
        "cwd": "samples/mobile/widgets/investment-portfolio"
      }
    }
  }
}
