{
  "name": "@dbk-olb-platform/template",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "targets": {
    "local-registry": {
      "executor": "@nx/js:verdaccio",
      "options": {
        "port": 4873,
        "config": ".verdaccio/config.yml",
        "storage": "tmp/local-registry/storage"
      }
    },
    "check-dependency-sync": {
      "executor": "@dbk-olb-platform/common-plugin:check-dependency-sync",
      "options": {
        "sourcePackageJsonPath": "{workspaceRoot}/package.json",
        "failOnMismatch": true
      }
    }
  }
}
